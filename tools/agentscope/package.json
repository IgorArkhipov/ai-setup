{
  "name": "agentscope",
  "private": true,
  "version": "0.1.0",
  "description": "Fixture-backed AgentScope bootstrap CLI",
  "type": "module",
  "engines": {
    "node": ">=25.9.0"
  },
  "bin": {
    "agentscope": "./dist/cli.js"
  },
  "scripts": {
    "biome:check": "biome check --config-path ../../biome.jsonc ../../",
    "biome:write": "biome check --write --config-path ../../biome.jsonc ../../",
    "build": "tsc -p tsconfig.json",
    "format": "npm run biome:write",
    "lint": "npm run biome:check",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
